---
import Base from '../layouts/Base.astro';
import fs from 'node:fs';
import path from 'node:path';

const raw = fs.readFileSync(path.resolve('src/content/pages/om-oss.md'), 'utf-8');
const title = raw.match(/title:\s*"(.+?)"/)?.[1] || 'Om oss';
const body = raw.split(/^---$/m).slice(2).join('---').trim();
---
<Base title={`${title} — Shilajit Sverige`} slug="/om-oss">
  <h1 set:html={title} />
  <article set:html={body} />
</Base>
