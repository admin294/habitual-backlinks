---
import siteConfig from '../data/site.json';
interface Props {
  title: string;
  description?: string;
  slug?: string;
  heroImage?: string;
}
const { title, description = siteConfig.tagline, slug = '', heroImage } = Astro.props;
const canonical = new URL(slug, Astro.site).toString();
---
<!doctype html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  {heroImage && <meta property="og:image" content={heroImage} />}
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" />
  <style is:global>
    :root {
      --color-bg: #ffffff;
      --color-bg-alt: #fafaf7;
      --color-bg-warm: #f9f5ef;
      --color-text: #1a1a1a;
      --color-text-muted: #6c6c6c;
      --color-text-soft: #8a8a8a;
      --color-accent: #5c3a25;
      --color-accent-soft: #e8d5b8;
      --color-border: #ebe4d8;
      --color-border-soft: #f0ece4;
      --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      --font-head: 'Lora', Georgia, serif;
      --max-width: 1140px;
      --content-width: 720px;
      --radius: 4px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
      --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: var(--font-body);
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.7;
      font-size: 17px;
      -webkit-font-smoothing: antialiased;
    }
    .container { max-width: var(--max-width); margin: 0 auto; padding: 0 1.5rem; }
    .container-narrow { max-width: var(--content-width); margin: 0 auto; padding: 0 1.5rem; }

    /* Header */
    .site-header {
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      padding: 1.25rem 0;
      position: sticky;
      top: 0;
      z-index: 100;
      backdrop-filter: saturate(180%) blur(12px);
      background: rgba(255, 255, 255, 0.85);
    }
    .site-header .container { display: flex; justify-content: space-between; align-items: center; }
    .brand {
      font-family: var(--font-head);
      font-size: 1.35rem;
      font-weight: 600;
      text-decoration: none;
      color: var(--color-text);
      letter-spacing: -0.01em;
    }
    .brand:hover { color: var(--color-accent); }
    .site-nav { display: flex; gap: 2rem; }
    .site-nav a {
      color: var(--color-text);
      text-decoration: none;
      font-size: 0.95rem;
      font-weight: 500;
      position: relative;
      padding: 0.25rem 0;
    }
    .site-nav a:hover { color: var(--color-accent); }
    .site-nav a::after {
      content: '';
      position: absolute;
      left: 0; right: 0; bottom: -2px;
      height: 2px;
      background: var(--color-accent);
      transform: scaleX(0);
      transition: transform 0.2s;
    }
    .site-nav a:hover::after { transform: scaleX(1); }

    /* Hero */
    .hero {
      padding: 5rem 0 3.5rem;
      text-align: center;
      background: linear-gradient(180deg, var(--color-bg-warm) 0%, var(--color-bg) 100%);
      margin-bottom: 3rem;
      border-bottom: 1px solid var(--color-border-soft);
    }
    .hero h1 {
      font-family: var(--font-head);
      font-size: clamp(2.2rem, 5vw, 3.4rem);
      line-height: 1.15;
      margin: 0 0 1rem;
      letter-spacing: -0.02em;
      font-weight: 600;
    }
    .hero p.lead {
      font-size: 1.15rem;
      color: var(--color-text-muted);
      max-width: 640px;
      margin: 0 auto 2rem;
    }

    /* Typography */
    h1, h2, h3, h4 {
      font-family: var(--font-head);
      line-height: 1.25;
      letter-spacing: -0.015em;
      color: var(--color-text);
      font-weight: 600;
    }
    h1 { font-size: 2.4rem; margin-top: 0; margin-bottom: 1rem; }
    h2 { font-size: 1.7rem; margin-top: 3rem; margin-bottom: 1rem; }
    h3 { font-size: 1.3rem; margin-top: 2rem; margin-bottom: 0.75rem; }
    article p, article li { font-size: 1.05rem; line-height: 1.75; }
    article p { margin: 1.25rem 0; }
    article ul, article ol { padding-left: 1.5rem; margin: 1.25rem 0; }
    article li { margin: 0.5rem 0; }
    article blockquote {
      border-left: 3px solid var(--color-accent);
      padding: 0.5rem 0 0.5rem 1.5rem;
      margin: 2rem 0;
      font-family: var(--font-head);
      font-style: italic;
      font-size: 1.15rem;
      color: var(--color-text-muted);
    }
    a { color: var(--color-accent); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 0.15s; }
    article a { border-bottom-color: var(--color-accent-soft); }
    article a:hover { border-bottom-color: var(--color-accent); }
    img { max-width: 100%; height: auto; border-radius: var(--radius); }
    article img { box-shadow: var(--shadow-sm); margin: 1.5rem 0; }

    /* Post meta */
    .post-meta {
      color: var(--color-text-soft);
      font-size: 0.9rem;
      margin: -0.5rem 0 2rem;
      font-weight: 500;
    }
    .post-meta time { color: var(--color-text-muted); }

    /* Post grid (home) */
    .section-heading {
      text-align: center;
      margin: 3rem 0 0.5rem;
    }
    .section-heading h2 {
      font-size: 1.9rem;
      margin: 0;
    }
    .section-heading p {
      color: var(--color-text-muted);
      margin: 0.5rem 0 0;
    }
    .post-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
      gap: 2rem;
      list-style: none;
      padding: 0;
      margin: 3rem 0 4rem;
    }
    .post-card {
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 1.75rem;
      transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
      display: flex;
      flex-direction: column;
    }
    .post-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-md);
      border-color: var(--color-accent-soft);
    }
    .post-card a { color: inherit; text-decoration: none; display: block; height: 100%; display: flex; flex-direction: column; }
    .post-card .card-title {
      font-family: var(--font-head);
      font-size: 1.25rem;
      font-weight: 600;
      line-height: 1.3;
      margin: 0 0 0.75rem;
      color: var(--color-text);
      letter-spacing: -0.01em;
    }
    .post-card:hover .card-title { color: var(--color-accent); }
    .post-card .card-excerpt {
      color: var(--color-text-muted);
      font-size: 0.95rem;
      line-height: 1.6;
      flex: 1;
    }
    .post-card .card-meta {
      color: var(--color-text-soft);
      font-size: 0.85rem;
      margin-top: 1.25rem;
      padding-top: 1rem;
      border-top: 1px solid var(--color-border-soft);
      font-weight: 500;
    }
    .read-more {
      display: inline-block;
      margin-top: 0.5rem;
      color: var(--color-accent);
      font-weight: 600;
      font-size: 0.9rem;
    }

    /* CTA */
    .cta-section {
      background: var(--color-bg-warm);
      padding: 3rem 1.5rem;
      border-radius: var(--radius);
      text-align: center;
      margin: 3rem 0;
    }
    .cta-section h2 { margin-top: 0; }
    .btn {
      display: inline-block;
      padding: 0.75rem 1.75rem;
      background: var(--color-accent);
      color: white !important;
      border-radius: var(--radius);
      font-weight: 600;
      font-size: 0.95rem;
      border-bottom: none !important;
      transition: opacity 0.2s;
    }
    .btn:hover { opacity: 0.9; }

    /* Footer */
    .site-footer {
      margin-top: 5rem;
      padding: 3rem 0 2rem;
      border-top: 1px solid var(--color-border);
      background: var(--color-bg-alt);
      color: var(--color-text-muted);
      font-size: 0.92rem;
    }
    .site-footer .footer-grid { display: flex; flex-wrap: wrap; gap: 2rem; justify-content: space-between; }
    .site-footer .brand { font-size: 1.1rem; }
    .site-footer nav { display: flex; gap: 1.5rem; }
    .site-footer a { color: var(--color-text-muted); }
    .site-footer .copyright {
      margin-top: 2rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--color-border-soft);
      font-size: 0.85rem;
      color: var(--color-text-soft);
      text-align: center;
    }

    /* Article wrapper */
    .article-wrapper {
      padding-bottom: 2rem;
    }

    /* Back link */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      margin: 2rem 0 0;
      color: var(--color-text-muted);
      font-weight: 500;
      font-size: 0.95rem;
    }
    .back-link:hover { color: var(--color-accent); }

    @media (max-width: 720px) {
      body { font-size: 16px; }
      .site-nav { gap: 1.25rem; }
      .site-nav a { font-size: 0.88rem; }
      .hero { padding: 3rem 0 2rem; }
      h1 { font-size: 1.85rem; }
      h2 { font-size: 1.45rem; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a class="brand" href="/">{siteConfig.brand}</a>
      <nav class="site-nav">
        {siteConfig.nav.map(({ label, href }) => (
          <a href={href}>{label}</a>
        ))}
      </nav>
    </div>
  </header>
  <main><slot /></main>
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <span class="brand">{siteConfig.brand}</span>
        <nav>
          {siteConfig.nav.map(({ label, href }) => (
            <a href={href}>{label}</a>
          ))}
        </nav>
      </div>
      <div class="copyright">© 2026 {siteConfig.brand}. Alla rättigheter förbehållna.</div>
    </div>
  </footer>
</body>
</html>
