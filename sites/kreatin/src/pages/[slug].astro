---
import Base from '../layouts/Base.astro';
import siteConfig from '../data/site.json';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const { default: cfg } = await import('../data/site.json');
  const items = [];
  const pagesDir = path.resolve('src/content/pages');
  if (fs.existsSync(pagesDir)) {
    for (const file of fs.readdirSync(pagesDir)) {
      const slug = file.replace(/\.md$/, '');
      if (slug === cfg.homepage_content) continue;
      const raw = fs.readFileSync(path.join(pagesDir, file), 'utf-8');
      const fm = raw.match(/^---\n([\s\S]*?)\n---/)?.[1] || '';
      items.push({ params: { slug }, props: {
        title: fm.match(/title:\s*"(.+?)"/)?.[1] || '',
        body: raw.split(/^---$/m).slice(2).join('---').trim(),
        kind: 'page', date: '', excerpt: ''
      }});
    }
  }
  const postsDir = path.resolve('src/content/posts');
  if (fs.existsSync(postsDir)) {
    for (const file of fs.readdirSync(postsDir)) {
      const raw = fs.readFileSync(path.join(postsDir, file), 'utf-8');
      const fm = raw.match(/^---\n([\s\S]*?)\n---/)?.[1] || '';
      const slug = fm.match(/slug:\s*"(.+?)"/)?.[1] || file.replace(/\.md$/, '');
      items.push({ params: { slug }, props: {
        title: fm.match(/title:\s*"(.+?)"/)?.[1] || '',
        body: raw.split(/^---$/m).slice(2).join('---').trim(),
        kind: 'post',
        date: fm.match(/date:\s*"(.+?)"/)?.[1] || '',
        excerpt: fm.match(/excerpt:\s*"(.+?)"/)?.[1] || ''
      }});
    }
  }
  return items;
}

const { title, body, kind, date, excerpt } = Astro.props;
const dateStr = date ? new Date(date).toLocaleDateString('sv-SE', { year:'numeric', month:'long', day:'numeric' }) : '';
const wordCount = body.replace(/<[^>]+>/g, '').split(/\s+/).filter(Boolean).length;
const readTime = Math.max(1, Math.round(wordCount / 200));
const slug = Astro.params.slug;
---
<Base title={`${title} — ${siteConfig.brand}`} description={excerpt || siteConfig.tagline} slug={`/${slug}`}>
  <article class="container-narrow article-wrapper">
    <h1 set:html={title} />
    {kind === 'post' && <p class="post-meta">{dateStr && <><time>{dateStr}</time> · </>}{readTime} min läsning</p>}
    <div set:html={body} />
    <a href="/" class="back-link">← Tillbaka till startsidan</a>
  </article>
</Base>
