---
import Base from '../layouts/Base.astro';
import siteConfig from '../data/site.json';
import fs from 'node:fs';
import path from 'node:path';

const homepageSlug = siteConfig.homepage_content;
const pagePath = path.resolve(`src/content/pages/${homepageSlug}.md`);
let pageBody = '';
if (fs.existsSync(pagePath)) {
  const pageRaw = fs.readFileSync(pagePath, 'utf-8');
  pageBody = pageRaw.split(/^---$/m).slice(2).join('---').trim();
}

const postsDir = path.resolve('src/content/posts');
const posts = fs.existsSync(postsDir) ? fs.readdirSync(postsDir).map((file) => {
  const raw = fs.readFileSync(path.join(postsDir, file), 'utf-8');
  const fm = raw.match(/^---\n([\s\S]*?)\n---/)?.[1] || '';
  return {
    title: fm.match(/title:\s*"(.+?)"/)?.[1] || '',
    slug: fm.match(/slug:\s*"(.+?)"/)?.[1] || file.replace(/\.md$/, ''),
    date: fm.match(/date:\s*"(.+?)"/)?.[1] || '',
    excerpt: fm.match(/excerpt:\s*"(.+?)"/)?.[1] || '',
  };
}).sort((a, b) => b.date.localeCompare(a.date)) : [];

const { hero, stats, features, features_eyebrow, features_heading, features_lead,
        research_eyebrow, research_heading, research_lead, research_stats } = siteConfig;
---
<Base title={`${siteConfig.brand} — ${siteConfig.tagline}`} description={siteConfig.tagline} slug="/">
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-text">
          <div class="eyebrow">{hero.eyebrow}</div>
          <h1>{hero.headline}</h1>
          <p class="lead">{hero.lead}</p>
          <div class="cta-row">
            <a class="btn btn-primary" href={hero.cta_primary.href}>{hero.cta_primary.label}</a>
            <a class="btn btn-outline" href={hero.cta_secondary.href}>{hero.cta_secondary.label}</a>
          </div>
        </div>
        <div class="hero-image">
          <img src={hero.image} alt={hero.image_alt} loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <section class="stats-bar">
    <div class="container">
      <div class="stats-grid">
        {stats.map((s) => (
          <div class="stat">
            <div class="value">{s.value}<span class="unit">{s.unit}</span></div>
            <div class="stat-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="features" id="hur-det-fungerar">
    <div class="container">
      <div class="section-eyebrow">{features_eyebrow}</div>
      <h2 class="section-heading">{features_heading}</h2>
      <p class="section-lead">{features_lead}</p>
      <div class="features-grid">
        {features.map((f) => (
          <div class="feature">
            <div class="icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="research">
    <div class="container">
      <div class="research-grid">
        <div class="research-text">
          <div class="section-eyebrow">{research_eyebrow}</div>
          <h2>{research_heading}</h2>
          <p>{research_lead}</p>
        </div>
        <div class="research-stats">
          {research_stats.map((rs) => (
            <div class="research-stat">
              <div class="big-num">{rs.value}</div>
              <p class="text">{rs.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {pageBody && (
    <section class="container-narrow article-wrapper">
      <article set:html={pageBody} />
    </section>
  )}

  {posts.length > 0 && (
    <section class="posts-section">
      <div class="container">
        <div class="section-eyebrow">BLOGGEN</div>
        <h2 class="section-heading">Senaste artiklarna</h2>
        <ul class="post-grid">
          {posts.map((p) => (
            <li class="post-card">
              <a href={`/${p.slug}`}>
                <h3 class="card-title">{p.title}</h3>
                <p class="card-excerpt">{p.excerpt}</p>
                <div class="card-meta">Läs mer →</div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}
</Base>
