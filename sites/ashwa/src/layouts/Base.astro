---
import siteConfig from '../data/site.json';
interface Props {
  title: string;
  description?: string;
  slug?: string;
}
const { title, description = siteConfig.tagline, slug = '' } = Astro.props;
const canonical = new URL(slug, Astro.site).toString();
const cta = siteConfig.hero?.cta_primary;
---
<!doctype html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  {siteConfig.hero?.image && <meta property="og:image" content={siteConfig.hero.image} />}
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" />
  <style is:global>
    :root {
      --color-bg: #ffffff;
      --color-bg-warm: #faf5ec;
      --color-bg-blob: #f4ead9;
      --color-bg-dark: #2d3142;
      --color-text: #1a1d2e;
      --color-text-muted: #5e6373;
      --color-text-soft: #8a8f9e;
      --color-accent: #d4922c;
      --color-accent-hover: #b87a1e;
      --color-accent-soft: #fef1d8;
      --color-border: #ebe7df;
      --font-body: 'Inter', -apple-system, sans-serif;
      --font-head: 'Plus Jakarta Sans', sans-serif;
      --max-width: 1180px;
      --content-width: 720px;
      --radius: 8px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
      --shadow-md: 0 8px 24px rgba(0,0,0,0.08);
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: var(--font-body);
      background: var(--color-bg);
      color: var(--color-text);
      line-height: 1.65;
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
    }
    .container { max-width: var(--max-width); margin: 0 auto; padding: 0 1.5rem; }
    .container-narrow { max-width: var(--content-width); margin: 0 auto; padding: 0 1.5rem; }

    /* Header */
    .site-header {
      background: rgba(255,255,255,0.92);
      backdrop-filter: saturate(180%) blur(12px);
      border-bottom: 1px solid var(--color-border);
      padding: 1.1rem 0;
      position: sticky; top: 0; z-index: 100;
    }
    .site-header .container { display: flex; justify-content: space-between; align-items: center; }
    .brand { font-family: var(--font-head); font-size: 1.25rem; font-weight: 800; text-decoration: none; color: var(--color-text); letter-spacing: -0.02em; }
    .brand:hover { color: var(--color-accent); }
    .site-nav { display: flex; gap: 2rem; align-items: center; }
    .site-nav a { color: var(--color-text); text-decoration: none; font-size: 0.95rem; font-weight: 500; }
    .site-nav a:hover { color: var(--color-accent); }
    .site-nav .btn-nav {
      background: var(--color-accent); color: white !important;
      padding: 0.6rem 1.25rem; border-radius: var(--radius);
      font-weight: 600; transition: background 0.15s;
    }
    .site-nav .btn-nav:hover { background: var(--color-accent-hover); }

    /* Hero — split layout med product image på blob */
    .hero {
      padding: 4rem 0 5rem;
      overflow: hidden;
    }
    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
    .hero-text .eyebrow {
      color: var(--color-accent);
      font-family: var(--font-head);
      font-weight: 700;
      font-size: 0.9rem;
      letter-spacing: 0.1em;
      margin-bottom: 1rem;
    }
    .hero-text h1 {
      font-family: var(--font-head);
      font-size: clamp(2rem, 4vw, 3rem);
      line-height: 1.15;
      margin: 0 0 1.25rem;
      letter-spacing: -0.025em;
      font-weight: 800;
    }
    .hero-text .lead {
      font-size: 1.1rem;
      color: var(--color-text-muted);
      margin: 0 0 2rem;
      max-width: 520px;
    }
    .cta-row { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn {
      display: inline-block;
      padding: 0.85rem 1.75rem;
      border-radius: var(--radius);
      font-family: var(--font-head);
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
      transition: all 0.15s;
      border: 2px solid transparent;
    }
    .btn-primary { background: var(--color-accent); color: white; }
    .btn-primary:hover { background: var(--color-accent-hover); }
    .btn-outline {
      background: transparent;
      color: var(--color-text);
      border-color: var(--color-text);
    }
    .btn-outline:hover { background: var(--color-text); color: white; }

    .hero-image {
      position: relative;
      display: flex; justify-content: center; align-items: center;
      min-height: 400px;
    }
    .hero-image::before {
      content: '';
      position: absolute; inset: 0;
      background: var(--color-bg-blob);
      border-radius: 50% 40% 55% 45% / 45% 55% 40% 60%;
      transform: rotate(-3deg) scale(0.95);
      z-index: 0;
    }
    .hero-image img {
      position: relative; z-index: 1;
      max-width: 380px;
      max-height: 480px;
      filter: drop-shadow(0 20px 30px rgba(0,0,0,0.15));
    }

    /* Stats bar — dark background */
    .stats-bar {
      background: var(--color-bg-dark);
      color: white;
      padding: 2.5rem 0;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      text-align: center;
    }
    .stat { position: relative; padding: 0 1rem; }
    .stat:not(:last-child)::after {
      content: ''; position: absolute; right: 0; top: 10%; bottom: 10%;
      width: 2px; background: rgba(255,255,255,0.15);
    }
    .stat .value { font-family: var(--font-head); font-size: 2.5rem; font-weight: 700; letter-spacing: -0.02em; }
    .stat .unit { display: block; font-size: 0.75rem; letter-spacing: 0.15em; opacity: 0.7; margin-top: 0.25rem; }
    .stat .stat-label { font-size: 0.9rem; opacity: 0.7; margin-top: 0.5rem; }

    /* Features */
    .features { padding: 5rem 0; }
    .section-eyebrow {
      text-align: center;
      color: var(--color-accent);
      font-family: var(--font-head);
      font-weight: 700;
      font-size: 0.9rem;
      letter-spacing: 0.1em;
      margin-bottom: 0.75rem;
    }
    .section-heading {
      text-align: center;
      font-family: var(--font-head);
      font-size: clamp(1.8rem, 3.5vw, 2.4rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      margin: 0 0 0.75rem;
    }
    .section-lead {
      text-align: center;
      color: var(--color-text-muted);
      max-width: 640px;
      margin: 0 auto 3rem;
    }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem 2.5rem;
    }
    .feature .icon {
      font-size: 2rem;
      width: 3rem; height: 3rem;
      display: inline-flex; align-items: center; justify-content: center;
      background: var(--color-accent-soft);
      border-radius: 50%;
      margin-bottom: 1rem;
    }
    .feature h3 {
      font-family: var(--font-head);
      font-size: 1.25rem;
      font-weight: 700;
      margin: 0 0 0.6rem;
      letter-spacing: -0.01em;
    }
    .feature p { color: var(--color-text-muted); margin: 0; line-height: 1.6; font-size: 0.96rem; }

    /* Research/stats section */
    .research { background: var(--color-bg-warm); padding: 5rem 0; }
    .research-grid {
      display: grid;
      grid-template-columns: 1fr 1.3fr;
      gap: 4rem;
      align-items: center;
    }
    .research-text h2 { text-align: left; margin: 0 0 1rem; font-size: clamp(1.6rem, 3vw, 2.2rem); }
    .research-text .section-eyebrow { text-align: left; }
    .research-text p { color: var(--color-text-muted); }
    .research-stats { display: flex; flex-direction: column; gap: 1.5rem; }
    .research-stat {
      display: grid; grid-template-columns: auto 1fr; gap: 1.5rem; align-items: start;
      padding-left: 1.25rem; border-left: 4px solid var(--color-accent);
    }
    .research-stat .big-num { font-family: var(--font-head); font-size: 2.5rem; font-weight: 800; line-height: 1; }
    .research-stat .text { color: var(--color-text-muted); margin: 0; padding-top: 0.3rem; }

    /* Article wrapper (for posts + pages) */
    .article-wrapper { padding: 4rem 0 2rem; }
    .article-wrapper h1 { font-family: var(--font-head); font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.2; margin: 0 0 1rem; }
    article h2 { font-family: var(--font-head); font-size: 1.6rem; font-weight: 700; margin: 2.5rem 0 1rem; letter-spacing: -0.015em; }
    article h3 { font-family: var(--font-head); font-size: 1.2rem; font-weight: 700; margin: 2rem 0 0.75rem; }
    article p, article li { font-size: 1.05rem; line-height: 1.75; }
    article p { margin: 1.25rem 0; }
    article ul, article ol { padding-left: 1.5rem; margin: 1.25rem 0; }
    article a { color: var(--color-accent); border-bottom: 1px solid var(--color-accent-soft); text-decoration: none; }
    article a:hover { border-bottom-color: var(--color-accent); }
    article img { max-width: 100%; border-radius: var(--radius); margin: 1.5rem 0; }
    article blockquote {
      border-left: 3px solid var(--color-accent);
      padding: 0.5rem 0 0.5rem 1.5rem;
      margin: 2rem 0;
      font-family: var(--font-head);
      font-style: italic;
      font-size: 1.1rem;
      color: var(--color-text-muted);
    }
    .post-meta { color: var(--color-text-soft); font-size: 0.9rem; margin: -0.5rem 0 2rem; }

    /* Post grid (för blog/home list) */
    .posts-section { padding: 4rem 0; background: var(--color-bg-warm); }
    .post-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 1.75rem; list-style: none; padding: 0; margin: 3rem 0 0;
    }
    .post-card {
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 1.75rem;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .post-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
    .post-card a { color: inherit; text-decoration: none; display: flex; flex-direction: column; height: 100%; }
    .post-card .card-title { font-family: var(--font-head); font-size: 1.2rem; font-weight: 700; margin: 0 0 0.6rem; letter-spacing: -0.01em; line-height: 1.3; }
    .post-card:hover .card-title { color: var(--color-accent); }
    .post-card .card-excerpt { color: var(--color-text-muted); font-size: 0.95rem; flex: 1; }
    .post-card .card-meta { color: var(--color-accent); font-weight: 600; font-size: 0.85rem; margin-top: 1.25rem; }

    /* Footer */
    .site-footer { padding: 3rem 0 2rem; border-top: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-text-muted); font-size: 0.92rem; }
    .footer-grid { display: flex; flex-wrap: wrap; gap: 2rem; justify-content: space-between; align-items: center; }
    .site-footer nav { display: flex; gap: 1.5rem; }
    .site-footer a { color: var(--color-text-muted); text-decoration: none; }
    .site-footer a:hover { color: var(--color-accent); }
    .copyright { margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border); font-size: 0.85rem; text-align: center; color: var(--color-text-soft); }

    .back-link { display: inline-flex; gap: 0.4rem; margin: 2rem 0 0; color: var(--color-text-muted); font-weight: 500; text-decoration: none; }
    .back-link:hover { color: var(--color-accent); }

    @media (max-width: 780px) {
      .hero-grid, .research-grid, .features-grid { grid-template-columns: 1fr; gap: 2rem; }
      .hero { padding: 2.5rem 0 3rem; }
      .hero-image { min-height: 280px; }
      .hero-image img { max-width: 260px; }
      .stats-grid { grid-template-columns: 1fr; gap: 1.5rem; }
      .stat:not(:last-child)::after { display: none; }
      .stat { padding: 1rem 0; border-bottom: 1px solid rgba(255,255,255,0.15); }
      .stat:last-child { border: 0; }
      .features { padding: 3rem 0; }
      .research { padding: 3rem 0; }
      .site-nav { gap: 1rem; }
      .site-nav a:not(.btn-nav) { display: none; }
    }

    /* How it works section */
    .howitworks { padding: 5rem 0; }
    .howitworks-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 4rem; align-items: center; }
    .howitworks-text .section-eyebrow { text-align: left; }
    .howitworks-text h2 { text-align: left; font-family: var(--font-head); font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; letter-spacing: -0.02em; margin: 0 0 1rem; }
    .howitworks-text p { color: var(--color-text-muted); font-size: 1.05rem; line-height: 1.75; }
    .howitworks-image img { width: 100%; border-radius: var(--radius); box-shadow: var(--shadow-md); }
    
    /* Dosering CTA section */
    .dosering { background: var(--color-bg-warm); padding: 5rem 0; text-align: center; }
    
    /* FAQ accordion */
    .faq { padding: 5rem 0; background: var(--color-bg); }
    .faq-list { margin-top: 3rem; display: flex; flex-direction: column; gap: 0.75rem; }
    .faq-item {
      background: var(--color-bg-warm);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      cursor: pointer;
    }
    .faq-item summary {
      font-family: var(--font-head);
      font-weight: 700;
      font-size: 1.05rem;
      list-style: none;
      display: flex; justify-content: space-between; align-items: center; gap: 1rem;
      color: var(--color-text);
    }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after {
      content: '+';
      font-size: 1.5rem;
      line-height: 1;
      color: var(--color-accent);
      transition: transform 0.2s;
      font-weight: 400;
    }
    .faq-item[open] summary::after { content: '−'; }
    .faq-item p {
      margin: 1rem 0 0;
      color: var(--color-text-muted);
      line-height: 1.65;
    }
    
    @media (max-width: 780px) {
      .howitworks-grid { grid-template-columns: 1fr; gap: 2rem; }
      .howitworks { padding: 3rem 0; }
      .dosering { padding: 3rem 0; }
      .faq { padding: 3rem 0; }
    }

  </style>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a class="brand" href="/">{siteConfig.brand}</a>
      <nav class="site-nav">
        {siteConfig.nav.map(({ label, href }) => (
          <a href={href}>{label}</a>
        ))}
        {cta && <a class="btn-nav" href={cta.href}>Testa {siteConfig.brand}</a>}
      </nav>
    </div>
  </header>
  <main><slot /></main>
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <a class="brand" href="/">{siteConfig.brand}</a>
        <nav>
          {siteConfig.nav.map(({ label, href }) => (
            <a href={href}>{label}</a>
          ))}
        </nav>
      </div>
      <div class="copyright">© 2026 {siteConfig.brand}. Alla rättigheter förbehållna.</div>
    </div>
  </footer>
</body>
</html>
