---
import Base from '../layouts/Base.astro';
import siteConfig from '../data/site.json';
import fs from 'node:fs';
import path from 'node:path';

const homepageSlug = siteConfig.homepage_content;
const pageRaw = fs.readFileSync(path.resolve(`src/content/pages/${homepageSlug}.md`), 'utf-8');
const pageTitle = pageRaw.match(/title:\s*"(.+?)"/)?.[1] || siteConfig.brand;
const pageBody = pageRaw.split(/^---$/m).slice(2).join('---').trim();

// Posts listing
const postsDir = path.resolve('src/content/posts');
const posts = fs.existsSync(postsDir) ? fs.readdirSync(postsDir).map((file) => {
  const raw = fs.readFileSync(path.join(postsDir, file), 'utf-8');
  const fm = raw.match(/^---\n([\s\S]*?)\n---/)?.[1] || '';
  return {
    title: fm.match(/title:\s*"(.+?)"/)?.[1] || '',
    slug: fm.match(/slug:\s*"(.+?)"/)?.[1] || file.replace(/\.md$/, ''),
    date: fm.match(/date:\s*"(.+?)"/)?.[1] || '',
    excerpt: fm.match(/excerpt:\s*"(.+?)"/)?.[1] || '',
  };
}).sort((a, b) => b.date.localeCompare(a.date)) : [];
---
<Base title={`${siteConfig.brand} — ${siteConfig.tagline}`} description={siteConfig.tagline} slug="/">
  <article set:html={pageBody} />
  {posts.length > 0 && (
    <>
      <h2>Senaste artiklarna</h2>
      <ul class="post-list">
        {posts.map((p) => (
          <li>
            <a href={`/${p.slug}`}>
              <span class="title">{p.title}</span>
              <span class="excerpt">{p.excerpt}</span>
            </a>
          </li>
        ))}
      </ul>
    </>
  )}
</Base>
