---
interface Props {
  title: string;
  description?: string;
  slug?: string;
}
const { title, description = 'Allt om sea moss — fördelar, dosering och vetenskap.', slug = '' } = Astro.props;
const canonical = new URL(slug, Astro.site).toString();
---
<!doctype html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <title>{title}</title>
  <style is:global>
    :root {
      --color-bg: #fdf8f1;
      --color-text: #2a1f15;
      --color-accent: #3d7a5f;
      --color-muted: #6b5d4d;
      --font-body: 'Georgia', serif;
      --font-head: 'Helvetica Neue', Arial, sans-serif;
      --max-width: 720px;
    }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: var(--font-body); background: var(--color-bg); color: var(--color-text); line-height: 1.6; font-size: 18px; }
    .container { max-width: var(--max-width); margin: 0 auto; padding: 0 1.25rem; }
    header { background: #fff; border-bottom: 1px solid #ead9c4; padding: 1rem 0; margin-bottom: 2rem; }
    header .container { display: flex; justify-content: space-between; align-items: center; }
    header a.brand { font-family: var(--font-head); font-size: 1.2rem; font-weight: 700; text-decoration: none; color: var(--color-accent); }
    nav a { color: var(--color-text); text-decoration: none; margin-left: 1.25rem; font-family: var(--font-head); font-size: 0.95rem; }
    nav a:hover { color: var(--color-accent); }
    h1, h2, h3 { font-family: var(--font-head); line-height: 1.25; color: var(--color-text); }
    h1 { font-size: 2rem; margin-top: 0; }
    h2 { font-size: 1.5rem; margin-top: 2.5rem; }
    h3 { font-size: 1.2rem; }
    a { color: var(--color-accent); }
    img { max-width: 100%; height: auto; border-radius: 6px; }
    .post-meta { color: var(--color-muted); font-size: 0.9rem; font-family: var(--font-head); margin-bottom: 2rem; }
    .post-list { list-style: none; padding: 0; }
    .post-list li { padding: 1rem 0; border-bottom: 1px solid #ead9c4; }
    .post-list a { text-decoration: none; color: var(--color-text); display: block; }
    .post-list a:hover { color: var(--color-accent); }
    .post-list .title { font-family: var(--font-head); font-size: 1.1rem; font-weight: 700; margin-bottom: 0.25rem; display: block; }
    .post-list .excerpt { color: var(--color-muted); font-size: 0.95rem; }
    footer { margin-top: 4rem; padding: 2rem 0; border-top: 1px solid #ead9c4; color: var(--color-muted); font-size: 0.85rem; text-align: center; }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <a class="brand" href="/">Sea Moss Gummies</a>
      <nav>
        <a href="/om-oss">Om oss</a>
        <a href="/kontakta-oss">Kontakt</a>
      </nav>
    </div>
  </header>
  <main class="container"><slot /></main>
  <footer>
    <div class="container">© 2026 Sea Moss Gummies · <a href="/om-oss">Om</a> · <a href="/kontakta-oss">Kontakt</a></div>
  </footer>
</body>
</html>
